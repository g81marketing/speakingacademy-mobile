# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (via Prisma) ───────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local:
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/speaking_academy?schema=public"
# Nuvem (ex: Supabase / Railway / Render):
# DATABASE_URL="postgresql://user:pass@host:5432/speaking_academy"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria_de_64_chars
JWT_EXPIRES_IN=7d

# ── Mercado Pago (assinaturas via SITE / web) ─────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
PREMIUM_PRICE_BRL=19.90
PREMIUM_NAME=Speaking Academy Premium
BACKEND_URL=http://localhost:3000
# MP_SUCCESS_URL=https://seu-backend.com/subscription/return

# ── Google Play Billing (assinaturas via APP Android) ─────────────────────────
# applicationId do app no Play Console
GOOGLE_PACKAGE_NAME=com.speakingacademy.app
# Forneça UMA das duas opções abaixo (JSON inline OU caminho do arquivo):
# 1) JSON da service account em linha única (recomendado em produção):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# 2) Caminho para o arquivo .json da service account:
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./secrets/google-service-account.json
