{
  "expo": {
    "name": "Speaking Academy",
    "slug": "speaking-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon-square.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0818"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "O Speaking Academy precisa do microfone para avaliar sua pronúncia."
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.speakingacademy.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "O Speaking Academy precisa do microfone para avaliar sua pronúncia.",
        "NSSpeechRecognitionUsageDescription": "O Speaking Academy usa reconhecimento de voz para avaliar sua fala."
      }
    },
    "android": {
      "package": "com.speakingacademy.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-square.png",
        "backgroundColor": "#0A0818"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "07bba715-0799-4263-90e6-9da8b7b201e4"
      }
    }
  }
}
